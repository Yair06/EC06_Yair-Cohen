# =========================================
# Fichier .env.dist — template de configuration
# =========================================
# Copier ce fichier en .env et remplir les valeurs réelles.
# Le fichier .env n'est PAS versionné (cf. .gitignore).

# --- Application ---
NODE_ENV=development
PORT=3000

# --- Base de données PostgreSQL ---
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=changeme
POSTGRES_DB=skillhub_db
DATABASE_URL=postgresql://skillhub:changeme@db:5432/skillhub_db
